# ===================================================================
# NewsLens — Environment Variables
# ===================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ===================================================================

# ---------- Guardian API (free — https://open-platform.theguardian.com/access/) ----------
GUARDIAN_API_KEY=your_key_here
GUARDIAN_SECTIONS=technology,business,money,world,science

# ---------- Kafka ----------
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_RAW=raw-news
KAFKA_TOPIC_FAILED=news-failed

# ---------- LLM Backend: "ollama" (local) or "groq" (free API) ----------
LLM_BACKEND=ollama
OLLAMA_BASE_URL=http://ollama:11434
GROQ_API_KEY=                       # only needed if LLM_BACKEND=groq

# ---------- Weaviate ----------
WEAVIATE_URL=http://weaviate:8085

# ---------- Flink ----------
FLINK_JOBMANAGER_URL=http://flink-jobmanager:8081
FLINK_CHECKPOINT_DIR=/tmp/flink-checkpoints
FLINK_PARALLELISM=1
FLINK_CHECKPOINT_INTERVAL_MS=60000

# ---------- Discord (optional — dead-letter alerts) ----------
DISCORD_WEBHOOK_URL=

# ---------- Airflow ----------
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=sqlite:////opt/airflow/airflow.db

# ---------- OpenLineage → Marquez ----------
AIRFLOW__OPENLINEAGE__TRANSPORT={"type":"http","url":"http://marquez:5000"}

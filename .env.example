# ===================================================================
# NewsLens — Environment Variables
# ===================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ===================================================================

# ---------- Guardian API (free — https://open-platform.theguardian.com/access/) ----------
GUARDIAN_API_KEY=your_key_here
GUARDIAN_SECTIONS=technology,business,money,world,science

# ---------- Kafka ----------
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_RAW=raw-news
KAFKA_TOPIC_FAILED=news-failed

# ---------- LLM Backend: "ollama" (local) or "groq" (free API) ----------
LLM_BACKEND=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=mistral
GROQ_API_KEY=                       # only needed if LLM_BACKEND=groq
GROQ_MODEL=llama3-8b-8192
LLM_TIMEOUT_SECONDS=30

# ---------- Enrichment Worker ----------
ENRICHMENT_CONSUMER_GROUP=enrichment-worker
KAFKA_TOPIC_TECH=tech-news
KAFKA_TOPIC_FINANCE=finance-news
KAFKA_TOPIC_WORLD=world-news

# ---------- Weaviate ----------
WEAVIATE_URL=http://weaviate:8085

# ---------- Quality Gate ----------
KAFKA_TOPIC_ENRICHED=enriched-news
KAFKA_TOPIC_VALIDATED=validated-news
QUALITY_GATE_CONSUMER_GROUP=quality-gate
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
MAX_RECENCY_DAYS=7

# ---------- Flink ----------
FLINK_JOBMANAGER_URL=http://flink-jobmanager:8081
FLINK_CHECKPOINT_DIR=/tmp/flink-checkpoints
FLINK_PARALLELISM=1
FLINK_CHECKPOINT_INTERVAL_MS=60000

# ---------- Discord (optional — dead-letter alerts) ----------
DISCORD_WEBHOOK_URL=

# ---------- Airflow ----------
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=sqlite:////opt/airflow/airflow.db

# ---------- OpenLineage → Marquez ----------
AIRFLOW__OPENLINEAGE__TRANSPORT={"type":"http","url":"http://marquez:5000"}
